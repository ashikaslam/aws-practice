[Unit]
Description=Gunicorn daemon for Django DRF API
After=network.target

[Service]
User=ubuntu
Group=www-data
WorkingDirectory=/home/ubuntu/aws-practice
EnvironmentFile=/home/ubuntu/aws-practice/.env
ExecStart=/home/ubuntu/aws-practice/.venv/bin/gunicorn \
    --workers 3 \
    --bind unix:/home/ubuntu/aws-practice/gunicorn.sock \
    config.wsgi:application

[Install]
WantedBy=multi-user.target
